{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zapret2",
  "version": "1.1.0",
  "identifier": "com.zapret2.gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zapret2",
        "width": 380,
        "height": 720,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../bin/**/*": "bin/",
      "../../exe/**/*": "exe/",
      "../../utils/**/*": "utils/",
      "../../presets/**/*": "presets/",
      "../../lists/**/*": "lists/",
      "../../lua/**/*": "lua/",
      "../../windivert.filter/**/*": "windivert.filter/",
      "../../service.bat": "service.bat"
    }
  }
}
